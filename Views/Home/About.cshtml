@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="breadcrumb-container">
    <div class="container">
        <ul class="breadcrumb">
            <li><a href="/">Trang chủ</a></li>
            <li>Giới thiệu</li>
        </ul>
    </div>
</div>

<div class="container page-content margin-bottom-50">
    <div class="about-hero">
        <div class="about-hero-text">
            <h1 class="page-title">Về Protech Systems</h1>
            <p class="subtitle">Thế giới công nghệ chính hãng - Uy tín tạo dựng niềm tin</p>
        </div>
    </div>

    <!-- Company Intro -->
    <section class="about-intro-grid">
        <div class="about-intro-content">
            <h2>Câu chuyện thương hiệu</h2>
            <p>Được thành lập từ năm 2018 với mục tiêu ban đầu là mang các dòng điện thoại xách tay chất lượng cao đến tay người tiêu dùng Việt Nam, <strong>Protech Systems</strong> đã không ngừng chuyển mình phát triển mạnh mẽ. Đến nay, chúng tôi tự hào trở thành đối tác bán lẻ chính thức của nhiều thương hiệu công nghệ khổng lồ toàn cầu như Apple, Samsung, ASUS, JBL, Anker...</p>
            <p>Với slogan <strong>"Uy tín tạo dựng niềm tin"</strong>, mỗi sản phẩm bán ra tại hệ thống showroom của Protech Systems đều cam kết là sản phẩm chính hãng 100%, bảo hành chuẩn hãng với mức giá cạnh tranh nhất đi kèm các chính sách hậu mãi xuất sắc.</p>
        </div>
        <div class="about-intro-image">
            <img src="https://images.unsplash.com/photo-1542744094-3a31f103e35f?q=80&w=600&auto=format&fit=crop" alt="Showroom Protech Systems" class="rounded shadow" />
        </div>
    </section>

    <!-- Mission - Vision - Values -->
    <section class="about-mission-grid">
        <div class="mission-card">
            <div class="card-icon"><i class="fas fa-eye text-red"></i></div>
            <h3>Tầm nhìn</h3>
            <p>Trở thành chuỗi cửa hàng bán lẻ thiết bị công nghệ và giải pháp số hàng đầu Việt Nam vào năm 2030, mang lại trải nghiệm mua sắm tuyệt vời nhất cho mọi khách hàng.</p>
        </div>
        <div class="mission-card">
            <div class="card-icon"><i class="fas fa-bullseye text-red"></i></div>
            <h3>Sứ mệnh</h3>
            <p>Cung cấp sản phẩm công nghệ chất lượng cao, giúp nâng tầm cuộc sống số của người tiêu dùng Việt Nam. Đóng góp vào sự phát triển của xã hội thông qua các sản phẩm chất lượng.</p>
        </div>
        <div class="mission-card">
            <div class="card-icon"><i class="fas fa-handshake text-red"></i></div>
            <h3>Giá trị cốt lõi</h3>
            <p><strong>Khách hàng là trọng tâm:</strong> Mọi hoạt động của chúng tôi đều hướng đến lợi ích khách hàng.<br><strong>Tận tâm - Uy tín:</strong> Luôn trung thực và nỗ lực hết mình phục vụ khách hàng.</p>
        </div>
    </section>

    <!-- Milestones -->
    <section class="about-milestones">
        <h2 class="section-title text-center margin-bottom-30">Chặng đường phát triển</h2>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-badge">2018</div>
                <div class="timeline-panel">
                    <h4>Thành lập Cửa hàng đầu tiên</h4>
                    <p>Mở cửa hàng đầu tiên tại Quận 10, TP. Hồ Chí Minh với chỉ 5 nhân viên.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-badge">2020</div>
                <div class="timeline-panel">
                    <h4>Mở rộng chi nhánh</h4>
                    <p>Mở thêm chi nhánh tại TP. Thủ Đức và Quận Bình Thạnh, nâng tổng số showroom tại TP. Hồ Chí Minh lên 5 điểm.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-badge">2023</div>
                <div class="timeline-panel">
                    <h4>Đối tác ủy quyền của Apple & Samsung</h4>
                    <p>Chính thức ký kết hợp tác bán lẻ chiến lược toàn diện với các thương hiệu Apple, Samsung, ASUS.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-badge">2026</div>
                <div class="timeline-panel">
                    <h4>Số hóa & Kỷ nguyên E-Commerce</h4>
                    <p>Ra mắt hệ thống mua sắm trực tuyến đa kênh Protech Systems Smart Web và cán mốc phục vụ 500,000 khách hàng toàn quốc.</p>
                </div>
            </div>
        </div>
    </section>
</div>
