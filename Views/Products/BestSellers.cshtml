@model IEnumerable<DATN.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm bán chạy nhất";
}

<div class="breadcrumb-container">
    <div class="container">
        <ul class="breadcrumb">
            <li><a href="/">Trang chủ</a></li>
            <li>Sản phẩm bán chạy</li>
        </ul>
    </div>
</div>

<div class="container margin-bottom-50">
    <div class="best-sellers-hero" style="background-image: linear-gradient(to right, rgba(229,57,53,0.9), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1200&auto=format&fit=crop');">
        <div class="hero-inner">
            <span class="badge-hot-tag"><i class="fas fa-fire"></i> HOT TRENDING</span>
            <h1>Sản phẩm bán chạy nhất</h1>
            <p>Khám phá các thiết bị công nghệ hàng đầu đang được mua nhiều nhất tại chuỗi showroom Protech Systems.</p>
        </div>
    </div>

    <div class="catalog-main margin-top-30">
        <div class="catalog-header-bar">
            <div class="catalog-info">
                <h2 class="section-title">Danh sách sản phẩm bán chạy</h2>
                <span>Hiển thị <strong>@Model.Count()</strong> sản phẩm được yêu thích nhất</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="products-grid-4">
                @foreach (var product in Model)
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted">Hiện tại chưa có dữ liệu sản phẩm bán chạy.</p>
        }
    </div>
</div>
